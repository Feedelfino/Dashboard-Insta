INSTAGRAM_APP_ID=teste                         # identificador do app criado no portal da Meta; por enquanto vamos usar valor fake
INSTAGRAM_APP_SECRET=teste                     # chave secreta do app da Meta; valor fake só para o projeto subir agora
REDIRECT_URI=http://localhost:8000/auth/callback   # endereço do backend que receberá o retorno do login OAuth
FRONTEND_URL=http://localhost:5173            # endereço do frontend React que vai conversar com o backend